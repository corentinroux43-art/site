---
import MainLayout from '../layouts/MainLayout.astro';
import CoherenceCardiaque from '../components/CoherenceCardiaque.astro';
import FlappyOsteo from '../components/FlappyOsteo.astro';
import Osteorunner from "../components/Osteorunner.astro";
import Reactivite from '../components/Reactivite.astro';
import Memory from '../components/Memory.astro';
import Quiz from '../components/Quiz.astro';
import Trouvelos from '../components/Trouvelos.astro';
import Anxiete from '../components/Anxiete.astro';
import PierreFeuilleCiseaux from '../components/PierreFeuilleCiseaux.astro';
---

<MainLayout
  id="top"
  title="Cabinet d'ostéopathie à Saint-Just-Malmont"
  description="Découvrez le cabinet d'ostéopathie de Saint-Just-Malmont et son environnement chaleureux.">

  <section class="games-section">
    <h1>Jeux et exercices</h1>
    <p class="intro">Choisissez un jeu ou un exercice interactif.</p><br><br>

    <div class="games-grid">
      <button class="game-card" data-open="flappy">
        <span>🐤</span>
        <h3>Flappy Ostéo</h3>
        <p>Évite les obstacles.</p>
      </button>

      <button class="game-card" data-open="breathing">
        <span>🫁</span>
        <h3>Cohérence cardiaque</h3>
        <p>Respire calmement.</p>
      </button>

      <button class="game-card" data-open="vertebra">
        <span>🦖</span>
        <h3>Le squelette coureur</h3>
        <p>Place les éléments.</p>
      </button>

      <button class="game-card" data-open="reaction">
        <span>⚡</span>
        <h3>Réflexes</h3>
        <p>Teste ton temps de réaction.</p>
      </button>

      <button class="game-card" data-open="memory">
        <span>🧠</span>
        <h3>Memory</h3>
        <p>Retrouve les paires.</p>
      </button>

      <button class="game-card" data-open="quiz">
        <span>❓</span>
        <h3>Quiz ostéo</h3>
        <p>Vrai ou faux.</p>
      </button>

      <button class="game-card" data-open="simple">
        <span>🎯</span>
        <h3>Trouve l’os</h3>
        <p>Clique sur la bonne icône.</p>
      </button>

      <button class="game-card" data-open="anxiety">
        <span>🌿</span>
        <h3>Auto-évaluation</h3>
        <p>Anxiété et symptômes.</p>
      </button>

      <button class="game-card" data-open="battle">
        <span>✂️</span>
        <h3>Pierre feuille ciseaux</h3>
        <p>Défie l’ordinateur.</p>
      </button>
    </div>
  </section>

  <div class="game-modal" data-modal>
    <div class="modal-content">
      <button class="close-modal" data-close aria-label="Fermer">✕</button>

      <div class="game-panel" data-panel="flappy">
        <FlappyOsteo />
      </div>

      <div class="game-panel" data-panel="breathing">
        <CoherenceCardiaque />
      </div>

      <div class="game-panel" data-panel="vertebra">
        <Osteorunner />
      </div>

      <div class="game-panel" data-panel="reaction">
        <Reactivite />
      </div>

      <div class="game-panel" data-panel="memory">
        <Memory />
      </div>

      <div class="game-panel" data-panel="quiz">
        <Quiz />
      </div>

      <div class="game-panel" data-panel="simple">
        <Trouvelos />
      </div>

      <div class="game-panel" data-panel="anxiety">
        <Anxiety />
      </div>

      <div class="game-panel" data-panel="battle">
        <PierreFeuilleCiseaux />
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .games-section {   /* Toute la page */
    max-width: 1100px;
    margin: 6rem auto 3rem auto;
    padding: 2rem;
    text-align: center;
  }

  .games-section h1 {   /* Titre h1 */
    color: #2f2f2f;
    margin-bottom: 0.5rem;
    font-size: 3.5rem;
  }

  .intro {   /* Texte d'introduction */
    color: #6f675f;
    margin-bottom: 2rem;
  }

  .games-grid {   /* Zone contenant les cartes */
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 6rem;
  }

  .game-card {   /* Cartes */
    min-height: 210px;
    padding: 2rem 1.5rem;
    border: none;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.50);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    transition: 0.2s ease;
    text-align: center;
  }

  .game-card:hover {   /* Animation au survol d'une carte */
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.12);
  }

  .game-card span {   /* Emoji du jeu */
    display: block;
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .game-card h3 {   /* Titre de la carte */
    margin: 0.5rem 0;
    color: #435c45;
    font-size: 1.3rem;
  }

  .game-card p {   /* Description de la carte */
    margin: 0;
    color: #6f675f;
  }

  .game-modal {   /* Fond derriere la carte */
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 9999;
    padding: 2rem;
  }

  .game-modal.active {   /* popup */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-content {   /* Cadre blanc de la popup */
    position: relative;
    width: min(1100px, 95vw);
    max-height: 90vh;
    overflow-y: auto;
    background: white;
    border-radius: 28px;
    padding: 2rem;
  }

  .close-modal {   /* Bouton fermé X */
    position: sticky;
    top: 0;
    margin-left: auto;
    display: block;
    z-index: 20;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 50%;
    background: #b76e4c;
    color: white;
    cursor: pointer;
    font-size: 1.2rem;
  }

  .game-panel {   /* Conteneur du jeu */
    display: none;
  }

  .game-panel.active {   /* Jeu actuellement affiché */
    display: block;
  }


  html {   /* Défilement de la page */
    scroll-behavior: smooth;
  }

  @media (max-width: 768px) {   /* Version mobile */
    .games-section {   /* Toute la page */
      width: calc(100% - 1rem);
      padding: 1rem 0;
    }

    .games-grid {   /* Zone contenant les cartes */
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem;
    }

    .game-card {   /* Cartes */
      min-height: 150px;
      padding: 1rem 0.6rem;
      border-radius: 18px;
    }

    .game-card span {   /* Emoji du jeu */
      font-size: 2.2rem;
      margin-bottom: 0.5rem;
    }

    .game-card h3 {   /* Titre d'une carte */
      font-size: 0.95rem;
    }

    .game-card p {   /* Description d'une carte */
      font-size: 0.8rem;
    }

    .game-modal {   /* Fond derriere la fenêtre */
      padding: 0.7rem;
    }

    .modal-content {   /* cadre blanc de la pop-up */
      padding: 1rem;
      border-radius: 20px;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {   /* Récupération des éléments */
    const modal = document.querySelector("[data-modal]");
    const closeBtn = document.querySelector("[data-close]");
    const cards = document.querySelectorAll("[data-open]");
    const panels = document.querySelectorAll("[data-panel]");

    function openGame(gameName) {   /* Ouverture du jeu */
      panels.forEach(function (panel) {
        panel.classList.remove("active");
      });

      const selectedPanel = document.querySelector('[data-panel="' + gameName + '"]');

      if (selectedPanel) {
        selectedPanel.classList.add("active");
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
      }
    }

    function closeGame() {   /* Fermeture du jeu */
      modal.classList.remove("active");
      document.body.style.overflow = "";

      panels.forEach(function (panel) {
        panel.classList.remove("active");
      });
    }

    cards.forEach(function (card) {   /* Ouverture du jeu lors d'un clic sur la carte */
      card.addEventListener("click", function () {
        openGame(card.getAttribute("data-open"));
      });
    });

    closeBtn.addEventListener("click", closeGame);   /* Fermeture via le bouton X */

    modal.addEventListener("click", function (event) {   /* Fermeture en cliquant en dehors de la fenetre */
      if (event.target === modal) {
        closeGame();
      }
    });

    document.addEventListener("keydown", function (event) {   /* Fermeture avec la touche Echap */
      if (event.key === "Escape") {
        closeGame();
      }
    });
  });
</script>
