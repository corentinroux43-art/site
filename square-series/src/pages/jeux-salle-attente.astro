---
import MainLayout from '../layouts/MainLayout.astro';
import CoherenceCardiaque from '../components/CoherenceCardiaque.astro';
import FlappyBird from '../components/FlappyBird.astro';
import VertebraStackGame from "../components/VertebraStackGame.astro";
import ReactionGame from '../components/ReactionGame.astro';
import MemoryOsteoGame from '../components/MemoryOsteoGame.astro';
import OsteoQuizGame from '../components/OsteoQuizGame.astro';
import SimpleOsteoGame from '../components/SimpleOsteoGame.astro';
import AnxietySelfCheck from '../components/AnxietySelfCheck.astro';
import SimpleBattleGame from '../components/SimpleBattleGame.astro';
---

<MainLayout
  id="top"
  title="Cabinet d'ostéopathie à Saint-Just-Malmont"
  description="Découvrez le cabinet d'ostéopathie de Saint-Just-Malmont et son environnement chaleureux."
>
  <section class="games-section">
    <h1>Jeux et exercices</h1>
    <p class="intro">Choisissez un jeu ou un exercice interactif.</p><br><br>

    <div class="games-grid">
      <button class="game-card" data-open="flappy">
        <span>🐤</span>
        <h3>Flappy Ostéo</h3>
        <p>Évite les obstacles.</p>
      </button>

      <button class="game-card" data-open="breathing">
        <span>🫁</span>
        <h3>Cohérence cardiaque</h3>
        <p>Respire calmement.</p>
      </button>

      <button class="game-card" data-open="vertebra">
        <span>🦖</span>
        <h3>Le squelette coureur</h3>
        <p>Place les éléments.</p>
      </button>

      <button class="game-card" data-open="reaction">
        <span>⚡</span>
        <h3>Réflexes</h3>
        <p>Teste ton temps de réaction.</p>
      </button>

      <button class="game-card" data-open="memory">
        <span>🧠</span>
        <h3>Memory</h3>
        <p>Retrouve les paires.</p>
      </button>

      <button class="game-card" data-open="quiz">
        <span>❓</span>
        <h3>Quiz ostéo</h3>
        <p>Vrai ou faux.</p>
      </button>

      <button class="game-card" data-open="simple">
        <span>🎯</span>
        <h3>Trouve l’os</h3>
        <p>Clique sur la bonne icône.</p>
      </button>

      <button class="game-card" data-open="anxiety">
        <span>🌿</span>
        <h3>Auto-évaluation</h3>
        <p>Anxiété et symptômes.</p>
      </button>

      <button class="game-card" data-open="battle">
        <span>✂️</span>
        <h3>Pierre feuille ciseaux</h3>
        <p>Défie l’ordinateur.</p>
      </button>
    </div>
  </section>

  <div class="game-modal" data-modal>
    <div class="modal-content">
      <button class="close-modal" data-close aria-label="Fermer">✕</button>

      <div class="game-panel" data-panel="flappy">
        <FlappyBird />
      </div>

      <div class="game-panel" data-panel="breathing">
        <CoherenceCardiaque />
      </div>

      <div class="game-panel" data-panel="vertebra">
        <VertebraStackGame />
      </div>

      <div class="game-panel" data-panel="reaction">
        <ReactionGame />
      </div>

      <div class="game-panel" data-panel="memory">
        <MemoryOsteoGame />
      </div>

      <div class="game-panel" data-panel="quiz">
        <OsteoQuizGame />
      </div>

      <div class="game-panel" data-panel="simple">
        <SimpleOsteoGame />
      </div>

      <div class="game-panel" data-panel="anxiety">
        <AnxietySelfCheck />
      </div>

      <div class="game-panel" data-panel="battle">
        <SimpleBattleGame />
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .games-section {
    max-width: 1100px;
    margin: 10rem auto 3rem auto;
    padding: 2rem;
    text-align: center;
}

  .games-section h1 {
    color: #435c45;
    margin-bottom: 0.5rem;
    font-size: 3.5rem;
  }

  .intro {
    color: #6f675f;
    margin-bottom: 2rem;
  }

  .games-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 6rem;
}

  .game-card {
    min-height: 210px;
    padding: 2rem 1.5rem;
    border: none;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.50);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    transition: 0.2s ease;
    text-align: center;
  }

  .game-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.12);
  }

  .game-card span {
    display: block;
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .game-card h3 {
    margin: 0.5rem 0;
    color: #435c45;
    font-size: 1.3rem;
  }

  .game-card p {
    margin: 0;
    color: #6f675f;
  }

  .game-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 9999;
    padding: 2rem;
  }

  .game-modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-content {
    position: relative;
    width: min(1100px, 95vw);
    max-height: 90vh;
    overflow-y: auto;
    background: white;
    border-radius: 28px;
    padding: 2rem;
  }

  .close-modal {
    position: sticky;
    top: 0;
    margin-left: auto;
    display: block;
    z-index: 20;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 50%;
    background: #b76e4c;
    color: white;
    cursor: pointer;
    font-size: 1.2rem;
  }

  .game-panel {
    display: none;
  }

  .game-panel.active {
    display: block;
  }


  html {
    scroll-behavior: smooth;
  }

  @media (max-width: 600px) {
    .games-section {
      padding: 1rem;
    }

    .game-modal {
      padding: 0.7rem;
    }

    .modal-content {
      padding: 1rem;
      border-radius: 20px;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const modal = document.querySelector("[data-modal]");
    const closeBtn = document.querySelector("[data-close]");
    const cards = document.querySelectorAll("[data-open]");
    const panels = document.querySelectorAll("[data-panel]");

    function openGame(gameName) {
      panels.forEach(function (panel) {
        panel.classList.remove("active");
      });

      const selectedPanel = document.querySelector('[data-panel="' + gameName + '"]');

      if (selectedPanel) {
        selectedPanel.classList.add("active");
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
      }
    }

    function closeGame() {
      modal.classList.remove("active");
      document.body.style.overflow = "";

      panels.forEach(function (panel) {
        panel.classList.remove("active");
      });
    }

    cards.forEach(function (card) {
      card.addEventListener("click", function () {
        openGame(card.getAttribute("data-open"));
      });
    });

    closeBtn.addEventListener("click", closeGame);

    modal.addEventListener("click", function (event) {
      if (event.target === modal) {
        closeGame();
      }
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        closeGame();
      }
    });
  });
</script>