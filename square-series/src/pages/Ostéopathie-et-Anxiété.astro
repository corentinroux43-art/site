---
import MainLayout from '../layouts/MainLayout.astro';
import Actualite from '../components/Actualite.astro';
import signature from '../assets/signature.png';
---
{/* Booster de métadonnées - renvoie sur la page index.astro */}

<MainLayout>
    <Actualite>
    </Actualite>
    <img src={signature.src} alt="Signature" class="signature" />
</MainLayout>

<style>

    .signature {

        display: block;

        margin: 3rem auto 0;

        width: min(500px, 80%);

        height: auto;

    }

</style>