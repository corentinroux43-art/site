---
import MainLayout from '../layouts/MainLayout.astro';
import Rendezvous from '../components/Rendezvous.astro';
import signature from '../assets/signature.png';
---

<MainLayout>
  <Rendezvous>
    </Rendezvous>
 <img src={signature.src} alt="Signature" class="signature" />
</MainLayout>

<style>

.signature {

    display: block;

    margin: 3rem auto 0;

    width: min(500px, 80%);

    height: auto;

}

</style>
