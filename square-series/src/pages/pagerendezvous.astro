---
import MainLayout from '../layouts/MainLayout.astro';
import Rendezvous from '../components/Rendezvous.astro';
import signature from '../assets/signature.png';
---

<MainLayout>
  <Rendezvous>
    </Rendezvous>
 <img src={signature.src} alt="Signature" class="signature" />
</MainLayout>

<style>

.signature {
    display: block;
    margin-top: 3rem;
    margin-left: auto;
    margin-right: auto;

    max-width: 500px;
    height: auto;
}

</style>