---
import MainLayout from '../layouts/MainLayout.astro';
import Actualite from '../components/Actualite.astro';
import signature from '../assets/signature.png';
---

<MainLayout>
    <Actualite>
    </Actualite>
    <img src={signature.src} alt="Signature" class="signature" />
</MainLayout>

<style>

.signature {
    display: block;
    margin-top: 3rem;
    margin-left: auto;
    margin-right: auto;

    max-width: 500px;
    height: auto;
}

</style>
