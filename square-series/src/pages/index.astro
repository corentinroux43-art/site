---
import MainLayout from '../layouts/MainLayout.astro';
import Actualite from '../components/Actualite.astro';
import signature from '../assets/signature.png';
---

<MainLayout id="top"
    title="Corentin Roux - Ostéopathe à Saint-Just-Malmont"
    description="Cabinet d'ostéopathie à Saint-Just-Malmont. Consultations au cabinet et à domicile."
>
    <div style="margin-top: 7rem;">
    <Actualite>
    </Actualite>
    </div>
    <img src={signature.src} alt="Signature de Corentin Roux, ostéopathe à Saint-Just-Malmont" class="signature" />
    <a href="#top" class="back-to-top">
    ↑
</a>
</MainLayout>

<style>

    .signature {

        display: block;

        margin: 3rem auto 0;

        width: min(500px, 80%);

        height: auto;

    }

.back-to-top {
    position: fixed;
    bottom: 30px;
    right: 30px;

    width: 45px;
    height: 45px;

    border-radius: 50%;

    background: #6c8b6f;
    color: white;

    text-decoration: none;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 1.4rem;

    box-shadow: 0 4px 10px rgba(0,0,0,0.15);

    transition: all 0.2s ease;
}

.back-to-top:hover {
    transform: translateY(-3px);
    background: #5a735d;
}

html {
    scroll-behavior: smooth;
}
</style>
