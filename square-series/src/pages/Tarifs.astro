---
import MainLayout from '../layouts/MainLayout.astro';
import Rendezvous from '../components/Rendezvous.astro';
import signature from '../assets/signature.png';
---
{/* Booster de métadonnées - renvoie sur la page Prendre-Rendez-Vous */}

<MainLayout>
    <Rendezvous>
    </Rendezvous>
    <img src={signature.src} alt="Signature" class="signature" />
</MainLayout>

<style>

.signature {

    display: block;

    margin: 3rem auto 0;

    width: min(500px, 80%);

    height: auto;

}

</style>