---
import MainLayout from '../layouts/MainLayout.astro';
import Presentation from '../components/Presentation.astro';
import signature from '../assets/signature.png';
---

<MainLayout>
    <Presentation>
    </Presentation>
    <img src={signature.src} alt="Signature" class="signature" />
</MainLayout>

<style>

.signature {
    display: block;
    margin-top: 3rem;
    margin-left: auto;
    margin-right: auto;

    max-width: 500px;
    height: auto;
}

</style>