<section class="memory-game" data-memory-game>
  <h2>Memory ostéopathie</h2>
  <p>Retrouve les paires d’icônes.</p>

  <div class="stats">
    <span data-moves>Coups : 0</span>
    <span data-message></span>
  </div>

  <div class="grid" data-grid></div>

  <button data-restart>Recommencer</button>
</section>

<style>
  .memory-game {
    max-width: 800px;
    margin: 3rem auto;
    padding: 2rem;
    text-align: center;
    background: #fff8ef;
    border-radius: 24px;
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 1rem 0;
    font-weight: bold;
    color: #435c45;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 120px);
    gap: 16px;
    justify-content: center;
    margin: 2rem auto;
  }

  .card {
    width: 120px;
    height: 120px;

    border: none;
    border-radius: 16px;

    background: #6c8b6f;
    color: white;

    font-size: 4rem;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;

    transition: transform 0.15s ease;
  }

  .card:hover {
    transform: scale(1.05);
  }

  .card.flipped,
  .card.matched {
    background: #fff;
    color: #435c45;
    border: 2px solid #d4c2aa;
  }

  .card.matched {
    opacity: 0.55;
    cursor: default;
  }

  button[data-restart] {
    padding: 0.8rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: #6c8b6f;
    color: white;
    cursor: pointer;
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: repeat(4, 90px);
      gap: 10px;
    }

    .card {
      width: 90px;
      height: 90px;
      font-size: 3rem;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-memory-game]").forEach((game) => {
    const grid = game.querySelector("[data-grid]");
    const movesText = game.querySelector("[data-moves]");
    const message = game.querySelector("[data-message]");
    const restart = game.querySelector("[data-restart]");

    const icons = ["🦴", "💀", "🩻", "💪", "🦵", "🧠", "🫁", "🫀"];

    let firstCard = null;
    let secondCard = null;
    let lock = false;
    let moves = 0;
    let matchedPairs = 0;

    function shuffle(array) {
      return [...array].sort(() => Math.random() - 0.5);
    }

    function startGame() {
      grid.innerHTML = "";
      firstCard = null;
      secondCard = null;
      lock = false;
      moves = 0;
      matchedPairs = 0;

      movesText.textContent = "Coups : 0";
      message.textContent = "";

      const cards = shuffle([...icons, ...icons]);

      cards.forEach((icon) => {
        const card = document.createElement("button");
        card.className = "card";
        card.textContent = "?";
        card.dataset.icon = icon;

        card.addEventListener("click", () => flipCard(card));

        grid.appendChild(card);
      });
    }

    function flipCard(card) {
      if (lock) return;
      if (card.classList.contains("flipped")) return;
      if (card.classList.contains("matched")) return;

      card.classList.add("flipped");
      card.textContent = card.dataset.icon;

      if (!firstCard) {
        firstCard = card;
        return;
      }

      secondCard = card;
      moves++;
      movesText.textContent = "Coups : " + moves;

      checkPair();
    }

    function checkPair() {
      const isMatch =
        firstCard.dataset.icon === secondCard.dataset.icon;

      if (isMatch) {
        firstCard.classList.add("matched");
        secondCard.classList.add("matched");

        firstCard = null;
        secondCard = null;

        matchedPairs++;

        if (matchedPairs === icons.length) {
          message.textContent = "Bravo, toutes les paires sont trouvées !";
        }

        return;
      }

      lock = true;

      setTimeout(() => {
        firstCard.classList.remove("flipped");
        secondCard.classList.remove("flipped");

        firstCard.textContent = "?";
        secondCard.textContent = "?";

        firstCard = null;
        secondCard = null;
        lock = false;
      }, 800);
    }

    restart.addEventListener("click", startGame);

    startGame();
  });
</script>