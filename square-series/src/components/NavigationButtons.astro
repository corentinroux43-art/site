---
import Button from "./Button.astro";
---

<div class="actions">
    <Button text="Accueil" href="/" />
    <Button text="Votre Ostéopathe" href="/Votre-Ostéopathe" />
    <Button text="Votre Cabinet" href="/Votre-Cabinet" />
    <Button text="Prendre rendez-vous" href="/Prendre-Rendez-Vous" />
    <Button text="Vos Questions" href="/Questions-Fréquentes" />
</div>

<style>

    .actions {

        display: flex;

        justify-content: center;

        gap: 3rem;

        flex-wrap: wrap;

        margin-top: -1.5rem;
        margin-bottom: -8rem;

    }

    @media (max-width: 768px) {

        .actions {

            flex-direction: row;

            gap: 0.5rem;

            margin-top: 1rem;

            margin-bottom: -5rem;

            padding: 0 0.5rem;

        }

    }
</style>
