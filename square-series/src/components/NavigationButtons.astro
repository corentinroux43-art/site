---
import Button from "./Button.astro";
---

<nav class="actions" aria-label="Navigation principale">
    <Button text="Accueil" href="/" />
    <Button text="Votre Ostéopathe" href="/votre-osteopathe" />
    <Button text="Votre Cabinet" href="/votre-cabinet" />
    <Button text="Prendre rendez-vous" href="/prendre-rendez-vous" />
    <Button text="Questions fréquentes" href="/questions-frequentes" />
    <Button text="Jeux en salle d'attente" href="/jeux-salle-attente"/>
</nav>

<style>

    .actions {

        display: flex;

        justify-content: center;

        gap: 3rem;

        flex-wrap: wrap;

        margin-top: -1.5rem;
        margin-bottom: -8rem;

    }

    @media (max-width: 768px) {

        .actions {

            flex-direction: row;

            gap: 0.5rem;

            margin-top: 1rem;

            margin-bottom: -5rem;

            padding: 0 0.5rem;

        }

    }
</style>
