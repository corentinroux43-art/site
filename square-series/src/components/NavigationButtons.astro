---
import Button from "./Button.astro";
---

<nav class="actions" aria-label="Navigation principale">
    <Button text="Accueil" href="/" />
    <Button text="Votre Ostéopathe" href="/votre-osteopathe" />
    <Button text="Votre Cabinet" href="/votre-cabinet" />
    <Button text="Prendre rendez-vous" href="/prendre-rendez-vous" />
</nav>

<style>

    .actions {   /* Fonction des boutons */

        display: flex;

        justify-content: center;

        gap: 2rem;

        flex-wrap: wrap;

        margin-top: -1.5rem;
        margin-bottom: -5rem;

    }

    @media (max-width: 768px) {   /* Version mobile */

        .actions {   /* Fonction des boutons */

            flex-direction: row;

            gap: 0.5rem;

            margin-top: 1rem;

            margin-bottom: -3rem;

            padding: 0 0.5rem;

        }

    }
</style>
