<div class="simple-game" data-simple-osteo-game>
  <h2>Trouve l’os</h2>
  <p>Cliquez sur « Commencer » pour lancer la partie. Un chronomètre de 30 secondes démarre : votre objectif est de cliquer sur le plus grand nombre possible de 🦴 avant la fin du temps imparti.</p>

  <p class="score" data-score>Score : 0</p>
  <p class="timer" data-timer>Temps : 30s</p>
  <p class="message" data-message></p>

  <div class="zone" data-zone></div>

  <button type="button" data-restart>Recommencer</button>
</div>

<style is:global>
  .simple-game {  /* Cadre du jeu */
    max-width: 500px;
    margin: 3rem auto;
    padding: 2rem;
    text-align: center;
    background: #fff8ef;
    border-radius: 24px;
  }

  .score, /* texte score, temps, message */
  .timer,
  .message {
    font-weight: bold;
    color: #435c45;
  }

  .zone {  /* Grille d'icones */
    display: grid;
    grid-template-columns: repeat(3, 70px);
    gap: 12px;
    justify-content: center;
    margin: 2rem 0;
  }

  .item {  /* Bouton icone */
    width: 70px;
    height: 70px;
    border: none;
    border-radius: 16px;
    background: radial-gradient(circle at 30% 30%,
            #b8d2bb 0%,
            #8FAF95 60%,
            #6c8b6f 100%);
    font-size: 2rem;
    cursor: pointer;
  }

  .item:disabled {  /* Icone désactivée */
    opacity: 0.5;
    cursor: not-allowed;
  }

  button {  /* Bouton classique */
    padding: 0.8rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: #6c8b6f;
    color: white;
    cursor: pointer;
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-simple-osteo-game]").forEach((game) => {  /* Récupération des données */
    const zone = game.querySelector("[data-zone]");
    const scoreText = game.querySelector("[data-score]");
    const timerText = game.querySelector("[data-timer]");
    const message = game.querySelector("[data-message]");
    const restart = game.querySelector("[data-restart]");

    let score = 0;  /* Récuparation des données */
    let timeLeft = 30;
    let finished = false;
    let timerInterval = null;

    function shuffle(array) {  /* Mélanger les icones */
      return [...array].sort(() => Math.random() - 0.5);
    }

    function createGrid() {  /* Crée et affiche une nouvelle grille d'icones */
      zone.innerHTML = "";

      const icons = shuffle(["🦴", "💀", "🩻", "💪", "🦵", "🧠", "🫁", "🫀", "💣"]); /* Mélange les icons */

      icons.forEach((icon) => {
        const btn = document.createElement("button"); /* Crée un bouton pour chaque icon */
        btn.type = "button";
        btn.className = "item";
        btn.textContent = icon;

        btn.addEventListener("click", () => {
          if (finished) return;

          if (icon === "🦴") {  /* Ajoute 1 point si on clique sur l'os */
            score++;
          } else {
            score = Math.max(0, score - 1);
          }

          scoreText.textContent = "Score : " + score;
          createGrid();   /* Change la position des icons apres chaque clic */
        });

        zone.appendChild(btn);
      });
    }

    function endGame() {  /* Termine la partie et bloque les boutons */
      finished = true;
      clearInterval(timerInterval);
      message.textContent = "Terminé ! Score final : " + score;

      zone.querySelectorAll("button").forEach((btn) => {
        btn.disabled = true;
      });
    }

    function startGame() {  /* Lance le jeu */
      score = 0;
      timeLeft = 30;
      finished = false;

      clearInterval(timerInterval);

      scoreText.textContent = "Score : 0";
      timerText.textContent = "Temps : 30s";
      message.textContent = "";

      createGrid();

      timerInterval = setInterval(() => {  /* Diminue le temps toutes les secondes */
        timeLeft--;
        timerText.textContent = "Temps : " + timeLeft + "s";

        if (timeLeft <= 0) {
          endGame();
        }
      }, 1000);
    }

    restart.addEventListener("click", startGame);  /* Relance le jeu au clic */

    startGame(); /* Lance automatiquement le jeu en chargement */
  });
</script>
