<section class="memory-game" data-memory-game>
  <h2>Memory ostéopathie</h2>
  <p>Retrouvez les paires d’icônes.</p>

  <div class="stats">   {/* Zone de statistiques */}
    <span data-moves>Coups : 0</span>  {/* Compteur de coups */}
    <span data-message></span>   {/* Message */}
  </div>

  <div class="grid" data-grid>   {/* Grille de cartes */}
  </div>

  <button data-restart>Recommencer</button>  {/* Recommencer */}
</section>

<style is:global>
  .memory-game {   /* Jeu complet */
    max-width: 1000px;
    margin: 3rem auto;
    padding: 2rem;
    text-align: center;
    background: #fff8ef;
    border-radius: 24px;
  }

  .stats {   /* Zone de statistique */
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 1rem 0;
    font-weight: bold;
    color: #435c45;
  }

  .grid {   /* Grille de cartes */
    display: grid;
    grid-template-columns: repeat(4, 100px);
    gap: 20px;
    justify-content: center;
    margin: 2rem auto;
  }

  .card {   /* Carte cachée */
    width: 100px;
    height: 100px;

    border: none;
    border-radius: 20px;

    background: radial-gradient(circle at 30% 30%,
      #b8d2bb 0%,
      #8FAF95 60%,
      #6c8b6f 100%);
    color: white;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;
    transition: transform 0.15s ease;
  }

  .card:hover {   /* Animation au survol */
    transform: scale(1.05);
  }

  .card.flipped,    /* Carte retournée */
  .card.matched {   /* Carte trouvée */
    background: #fff;
    color: #435c45;
    border: 2px solid #d4c2aa;
  }

  .card.matched {   /* Carte trouvée */
    opacity: 0.55;
    cursor: default;
  }

  button[data-restart] {   /* Bouton recommencer */
    padding: 0.8rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: #6c8b6f;
    color: white;
    cursor: pointer;
  }


  @media (max-width: 700px) {   /* Version mobile */
    .grid {   /* Grille de cartes */
      grid-template-columns: repeat(4, 85px);
      gap: 8px;
    }

    .card {  /* Cartes retournées */
      width: 85px;
      height: 85px;
      border-radius: 14px;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-memory-game]").forEach((game) => {  /* Récupération de tous les éléments */
    const grid = game.querySelector("[data-grid]");
    const movesText = game.querySelector("[data-moves]");
    const message = game.querySelector("[data-message]");
    const restart = game.querySelector("[data-restart]");
    const icons = ["🦴", "💀", "💪", "🦵", "🧠", "⭐", "❤️", "⚡"];

    let firstCard = null;    /* Parametres du jeu */
    let secondCard = null;
    let lock = false;
    let moves = 0;
    let matchedPairs = 0;

    function shuffle(array) {   /* Mélange les cartes */
      return [...array].sort(() => Math.random() - 0.5);
    }

    function startGame() {   /* initialise partie */
      grid.innerHTML = "";
      firstCard = null;
      secondCard = null;
      lock = false;
      moves = 0;
      matchedPairs = 0;

      movesText.textContent = "Coups : 0";
      message.textContent = "";

      const cards = shuffle([...icons, ...icons]);

      cards.forEach((icon) => {
        const card = document.createElement("button");

        card.className = "card";
        card.type = "button";
        card.textContent = "?";
        card.dataset.icon = icon;

        card.addEventListener("click", () => flipCard(card));

        grid.appendChild(card);
      });
    }

    function flipCard(card) {   /* Retourne une carte quand on clique dessus */
      if (lock) return;
      if (card.classList.contains("flipped")) return;
      if (card.classList.contains("matched")) return;

      card.classList.add("flipped");

      const scale = window.innerWidth <= 700 ? 2.7 : 3;

        card.innerHTML =
          "<span style='display:inline-block; transform:scale(" +
          scale +
          "); line-height:1;'>" +
          card.dataset.icon +
          "</span>";

      if (!firstCard) {
        firstCard = card;
        return;
      }

      secondCard = card;
      moves++;
      movesText.textContent = "Coups : " + moves;

      checkPair();
    }

    function checkPair() {   /* Vérifie si 2 cartes sont identiques */
      const isMatch =
        firstCard.dataset.icon === secondCard.dataset.icon;

      if (isMatch) {
        firstCard.classList.add("matched");
        secondCard.classList.add("matched");

        firstCard = null;
        secondCard = null;

        matchedPairs++;

        if (matchedPairs === icons.length) {
          message.textContent = "Bravo, toutes les paires sont trouvées !";
        }

        return;
      }

      lock = true;

      setTimeout(() => {   /* Attend 8sec avant de cacher 2 mauvaises cartes */
        firstCard.classList.remove("flipped");
        secondCard.classList.remove("flipped");

        firstCard.textContent = "?";
        secondCard.textContent = "?";

        firstCard = null;
        secondCard = null;
        lock = false;
      }, 800);
    }

    restart.addEventListener("click", startGame);   /* Recommencer */

    startGame(); /* Lance automatiquement la partie au chargement */
  });
</script>
