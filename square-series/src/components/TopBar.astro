---
const {
    image = "/Banner.png"
} = Astro.props;
---

<header class="hero">
    <img src={image} alt="Bannière" />
</header>

<style>
    .hero {
        width: min(1600px, calc(100% - 2rem));
        margin: -12rem auto;
    }

    .hero img {
    width: 100%;
    height: 750px;
    object-fit: contain;
}
</style>
