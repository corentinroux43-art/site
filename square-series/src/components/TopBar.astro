---
const {   /* Banniere */
    image = "/banniere-osteopathe-saint-just-malmont.png"
} = Astro.props;
---

<header class="hero">   {/* En-tête de la page */}
    <img src={image} alt="Corentin Roux, ostéopathe à Saint-Just-Malmont" 
    loading="eager"/>
</header>

<style>
    .hero {   /* Banniere complete */
        width: min(1600px, calc(100% - 2rem));
        margin-top: -10rem;
        margin-bottom: -12rem;
        margin-left: auto;
        margin-right: auto;
    }

    .hero img {   /* Image de la banniere */
        display: block;
        width: 100%;
        height: auto;
        max-height: 600px;
        object-fit: contain;
        margin: 0 auto;
    }

    @media (max-width: 1024px) {   /* Tablette */
        .hero {   /* Banniere complete */
            margin: -8rem auto;
        }

        .hero img {   /* Image de la banniere */
            max-height: 700px;
        }
    }

    @media (max-width: 768px) { /* Téléphone */
        .hero {   /* Banniere complete */
            width: calc(100% - 1rem);
            margin: -4rem auto;
        }

        .hero img {   /* Image de la banniere */
            width: 100%;
            max-width: 500px;
            height: auto;
        }
    }
</style>
