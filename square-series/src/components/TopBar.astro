---
const {
    image = "/Banner.png"
} = Astro.props;
---

<header class="hero">
    <img src={image} alt="Bannière" />
</header>

<style>
    .hero {
        width: min(1600px, calc(100% - 2rem));
        margin: -12rem auto;
    }

    .hero img {
    width: 100%;
    height: 750px;
    object-fit: contain;
    }

    @media (max-width: 768px) {

        .hero {

            width: calc(100% - 1rem);

            margin: -4rem auto;

        }

        .hero img {

            height: auto;

            max-height: 300px;

            object-fit: contain;

        }

    }
</style>
