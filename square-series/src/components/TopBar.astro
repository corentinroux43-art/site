---
const {
    image = "/Banner.png"
} = Astro.props;
---

<header class="hero">
    <img src={image} alt="Bannière" />
</header>

<style>
    .hero {
        width: min(1600px, calc(100% - 2rem));
        margin: -12rem auto;
    }

    .hero img {
        display: block;
        width: 100%;
        height: auto;
        max-height: 600px;
        object-fit: contain;
        margin: 0 auto;
    }

    /* Tablette */
    @media (max-width: 1024px) {
        .hero {
            margin: -8rem auto;
        }

        .hero img {
            max-height: 700px;
        }
    }

    /* Téléphone */
    @media (max-width: 768px) {
        .hero {
            width: calc(100% - 1rem);
            margin: -2rem auto 1rem;
        }

        .hero img {
            width: 100%;
            max-width: 500px;
            max-height: none;
            height: auto;
        }
    }
</style>
