<section class="bubble-game" data-bubble-game>
  <h2>Éclate les bulles</h2>
  <p>Clique sur 🦴 et ⭐, mais évite les 💣.</p>

  <div class="score" data-score>Score : 0</div>

  <div class="arena" data-arena>
    <div class="start-message" data-start-message>
      
    </div>
  </div>

  <button data-start>Commencer</button>
  <button data-restart>Recommencer</button>
</section>

<style>
  .bubble-game {
    max-width: 800px;
    margin: 3rem auto;
    padding: 2rem;
    text-align: center;
    background: #fff8ef;
    border-radius: 24px;
  }

  .score {
    margin-bottom: 1rem;
    font-weight: bold;
    color: #435c45;
  }

  .arena {
    position: relative;
    height: 75px;
    width: 500px;
    max-width: 100%;
    overflow: hidden;
    border: 3px solid #d4c2aa;
    border-radius: 18px;
    background: linear-gradient(#eaf4ea, #fff8ef);
    margin: 0 auto;
  }

  .start-message {
    position: absolute;
    inset: 0;
    z-index: 30;

    display: flex;
    align-items: center;
    justify-content: center;

    background: rgba(255,255,255,0.85);
    color: #435c45;

    font-weight: bold;
  }

  .bubble {
    position: absolute;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: rgba(255,255,255,0.75);
    border: 2px solid rgba(108,139,111,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    cursor: pointer;
    user-select: none;
  }

  .game-over::before {
    content: "Partie terminée";
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: bold;
    color: #435c45;
    z-index: 20;
  }

  button {
    margin-top: 1.5rem;
    margin-inline: 0.3rem;
    padding: 0.8rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: #6c8b6f;
    color: white;
    cursor: pointer;
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-bubble-game]").forEach((game) => {
    const arena = game.querySelector("[data-arena]");
    const scoreDisplay = game.querySelector("[data-score]");
    const restartBtn = game.querySelector("[data-restart]");
    const startBtn = game.querySelector("[data-start]");
    const startMessage = game.querySelector("[data-start-message]");

    let score = 0;
    let gameOver = false;
    let started = false;
    let interval;

    function updateScore() {
      scoreDisplay.textContent = "Score : " + score;
    }

    function endGame() {
      gameOver = true;
      started = false;
      arena.classList.add("game-over");
      clearInterval(interval);
    }

    function createBubble() {
      if (gameOver || !started) return;

      const bubble = document.createElement("div");
      const random = Math.random();

      let icon = "🦴";
      let points = 1;
      let type = "bone";

      if (random > 0.75 && random <= 0.9) {
        icon = "⭐";
        points = 2;
        type = "star";
      }

      if (random > 0.9) {
        icon = "💣";
        points = 0;
        type = "bomb";
      }

      bubble.className = "bubble";
      bubble.textContent = icon;
      bubble.dataset.type = type;

      let x = Math.random() * (arena.clientWidth - 60);
      let y = arena.clientHeight + 60;
      let speed = 1.5 + Math.random() * 1.5;

      bubble.style.left = x + "px";
      bubble.style.top = y + "px";

      arena.appendChild(bubble);

      bubble.addEventListener("click", () => {
        if (gameOver || !started) return;

        if (bubble.dataset.type === "bomb") {
          endGame();
        } else {
          score += points;
          updateScore();
          bubble.remove();
        }
      });

      function move() {
        if (gameOver || !started) {
          bubble.remove();
          return;
        }

        y -= speed;
        bubble.style.top = y + "px";

        if (y < -70) {
          bubble.remove();
          return;
        }

        requestAnimationFrame(move);
      }

      move();
    }

    function startGame() {
      if (started) return;

      started = true;
      gameOver = false;

      arena.classList.remove("game-over");
      startMessage.style.display = "none";

      clearInterval(interval);
      interval = setInterval(createBubble, 550);
    }

    function restartGame() {
      score = 0;
      gameOver = false;
      started = false;

      updateScore();
      clearInterval(interval);

      arena.classList.remove("game-over");
      arena.innerHTML = "";

      arena.appendChild(startMessage);
      startMessage.style.display = "flex";
    }

    startBtn.addEventListener("click", startGame);
    restartBtn.addEventListener("click", restartGame);

    restartGame();
  });
</script>