<section class="osteo-runner" data-runner>
  <h2>Le squelette coureur</h2>
  <p>Cliquez sur le jeu ou appuie sur <strong>Espace</strong> pour sauter.</p>

  <div class="game-viewport">
    <div class="game" data-game>
      <div class="score" data-score>Score : 0</div>
      <div class="player" data-player>🦴</div>
      <div class="obstacle" data-obstacle>📦</div>
    </div>
  </div>

  <button data-restart>Recommencer</button>
</section>

<style>
  .osteo-runner {
    width: 100%;
    max-width: 800px;
    margin: 3rem auto;
    padding: 2rem;
    box-sizing: border-box;
    text-align: center;
    background: #fff8ef;
    border-radius: 24px;
  }

  .game-viewport {
    width: 100%;
    overflow: hidden;
    border-radius: 18px;
  }

  .game {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
    border: 3px solid #d4c2aa;
    border-radius: 18px;
    background: linear-gradient(#eaf4ea, #fff8ef);
    cursor: pointer;
    box-sizing: border-box;
  }

  .game::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 35px;
    height: 4px;
    background: #6c8b6f;
  }

  .game.game-over::before {
    content: "Partie terminée";
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: bold;
    color: #435c45;
    z-index: 50;
  }

  .score {
    position: absolute;
    top: 12px;
    right: 15px;
    font-weight: bold;
    color: #435c45;
    z-index: 60;
  }

  .player {
    position: absolute;
    left: 60px;
    bottom: 38px;
    font-size: 42px;
    z-index: 10;
  }

  .obstacle {
    position: absolute;
    bottom: 38px;
    font-size: 36px;
    z-index: 10;
  }

  button {
    margin-top: 1.5rem;
    padding: 0.8rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: #6c8b6f;
    color: white;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .osteo-runner {
      padding: 0.5rem;
      margin: 0 auto;
      border-radius: 16px;
    }

    .osteo-runner h2 {
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }

    .osteo-runner p {
      font-size: 0.9rem;
      margin-bottom: 0.8rem;
    }

    .game-viewport {
      width: 100%;
      height: 140px;
    }

    .game {
      height: 140px;
      border-radius: 12px;
    }

    .player {
      left: 15px;
      bottom: 25px;
      font-size: 22px;
    }

    .obstacle {
      bottom: 25px;
      font-size: 20px;
    }

    .score {
      top: 8px;
      right: 10px;
      font-size: 0.8rem;
    }

    .game::after {
      bottom: 22px;
      height: 3px;
    }

    .game.game-over::before {
      font-size: 1.2rem;
    }

    button[data-restart] {
      margin-top: 1rem;
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-runner]").forEach((runner) => {
    const game = runner.querySelector("[data-game]");
    const player = runner.querySelector("[data-player]");
    const obstacle = runner.querySelector("[data-obstacle]");
    const scoreDisplay = runner.querySelector("[data-score]");
    const restartBtn = runner.querySelector("[data-restart]");

    let score = 0;
    let gameOver = false;

    let playerY = 0;
    let velocity = 0;
    let jumping = false;

    let obstacleX = 0;
    let speed = 5;
    let scoredThisObstacle = false;

    const playerWidth = 20;
    const obstacleWidth = 20;

    function isMobile() {
      return window.innerWidth <= 768;
    }

    function getGround() {
      return isMobile() ? 25 : 38;
    }

    function getPlayerX() {
      return isMobile() ? 15 : 60;
    }

    function getStartOffset() {
      return isMobile() ? 30 : 80;
    }

    function getRestartOffset() {
      return isMobile() ? 30 : 80;
    }

    function jump() {
      if (gameOver || jumping) return;

      velocity = isMobile() ? 10 : 15;
      jumping = true;
    }

    function restart() {
      score = 0;
      speed = isMobile() ? 3 : 5;
      gameOver = false;

      playerY = 0;
      velocity = 0;
      jumping = false;

      obstacleX = game.clientWidth + getStartOffset();
      scoredThisObstacle = false;

      scoreDisplay.textContent = "Score : 0";
      game.classList.remove("game-over");

      player.style.bottom = getGround() + "px";
      obstacle.style.left = obstacleX + "px";
    }

    function loop() {
      if (!gameOver) {
        const playerX = getPlayerX();
        const ground = getGround();

        velocity -= isMobile() ? 0.55 : 0.8;
        playerY += velocity;

        if (playerY <= 0) {
          playerY = 0;
          velocity = 0;
          jumping = false;
        }

        player.style.bottom = ground + playerY + "px";

        obstacleX -= speed;
        obstacle.style.left = obstacleX + "px";

        if (!scoredThisObstacle && obstacleX + obstacleWidth < playerX) {
          score++;
          scoreDisplay.textContent = "Score : " + score;
          scoredThisObstacle = true;
          speed += isMobile() ? 0.20 : 0.6;
        }

        if (obstacleX < -80) {
          obstacleX = game.clientWidth + getRestartOffset();
          scoredThisObstacle = false;
        }

        const obstacleTouchesPlayer =
          obstacleX < playerX + playerWidth &&
          obstacleX + obstacleWidth > playerX;

        const playerIsTooLow =
          playerY < (isMobile() ? 25 : 45);

        if (obstacleTouchesPlayer && playerIsTooLow) {
          gameOver = true;
          game.classList.add("game-over");
        }
      }

      requestAnimationFrame(loop);
    }

    game.addEventListener("click", jump);

    document.addEventListener("keydown", (event) => {
      if (event.code === "Space") {
        event.preventDefault();
        jump();
      }
    });

    restartBtn.addEventListener("click", restart);

    restart();
    loop();
  });
</script>
