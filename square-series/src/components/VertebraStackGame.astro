<section class="osteo-runner" data-runner>
  <h2>Le squelette coureur</h2>
  <p>Clique sur le jeu ou appuie sur <strong>Espace</strong> pour sauter.</p>

  <div class="game" data-game>
    <div class="score" data-score>Score : 0</div>
    <div class="player" data-player>🦴</div>
    <div class="obstacle" data-obstacle>📦</div>
  </div>

  <button data-restart>Recommencer</button>
</section>

<style>
  .osteo-runner {
    max-width: 800px;
    margin: 3rem auto;
    padding: 2rem;
    text-align: center;
    background: #fff8ef;
    border-radius: 24px;
  }

  .game {
    position: relative;
    height: 220px;
    overflow: hidden;
    border: 3px solid #d4c2aa;
    border-radius: 18px;
    background: linear-gradient(#eaf4ea, #fff8ef);
    cursor: pointer;
  }

  .game::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 35px;
    height: 4px;
    background: #6c8b6f;
  }

  .game.game-over::before {
    content: "Partie terminée";
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: bold;
    color: #435c45;
    z-index: 50;
  }

  .score {
    position: absolute;
    top: 12px;
    right: 15px;
    font-weight: bold;
    color: #435c45;
    z-index: 60;
  }

  .player {
    position: absolute;
    left: 60px;
    bottom: 38px;
    font-size: 42px;
    z-index: 10;
  }

  .obstacle {
    position: absolute;
    bottom: 38px;
    font-size: 36px;
    z-index: 10;
  }

  button {
    margin-top: 1.5rem;
    padding: 0.8rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: #6c8b6f;
    color: white;
    cursor: pointer;
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-runner]").forEach((runner) => {
    const game = runner.querySelector("[data-game]");
    const player = runner.querySelector("[data-player]");
    const obstacle = runner.querySelector("[data-obstacle]");
    const scoreDisplay = runner.querySelector("[data-score]");
    const restartBtn = runner.querySelector("[data-restart]");

    let score = 0;
    let gameOver = false;

    let playerY = 0;
    let velocity = 0;
    let jumping = false;

    let obstacleX = 0;
    let speed = 5;
    let scoredThisObstacle = false;

    const ground = 38;
    const playerX = 60;
    const playerWidth = 40;
    const obstacleWidth = 40;

    function jump() {
      if (gameOver || jumping) return;

      velocity = 15;
      jumping = true;
    }

    function restart() {
      score = 0;
      speed = 5;
      gameOver = false;

      playerY = 0;
      velocity = 0;
      jumping = false;

      obstacleX = game.clientWidth + 200;
      scoredThisObstacle = false;

      scoreDisplay.textContent = "Score : 0";
      game.classList.remove("game-over");

      player.style.bottom = ground + "px";
      obstacle.style.left = obstacleX + "px";
    }

    function loop() {
      if (!gameOver) {
        velocity -= 0.8;
        playerY += velocity;

        if (playerY <= 0) {
          playerY = 0;
          velocity = 0;
          jumping = false;
        }

        player.style.bottom = ground + playerY + "px";

        obstacleX -= speed;
        obstacle.style.left = obstacleX + "px";

        if (!scoredThisObstacle && obstacleX + obstacleWidth < playerX) {
          score++;
          scoreDisplay.textContent = "Score : " + score;
          scoredThisObstacle = true;
          speed += 0.2;
        }

        if (obstacleX < -80) {
          obstacleX = game.clientWidth + 150;
          scoredThisObstacle = false;
        }

        const obstacleTouchesPlayer =
          obstacleX < playerX + playerWidth &&
          obstacleX + obstacleWidth > playerX;

        const playerIsTooLow = playerY < 45;

        if (obstacleTouchesPlayer && playerIsTooLow) {
          gameOver = true;
          game.classList.add("game-over");
        }
      }

      requestAnimationFrame(loop);
    }

    game.addEventListener("click", jump);

    document.addEventListener("keydown", (event) => {
      if (event.code === "Space") {
        event.preventDefault();
        jump();
      }
    });

    restartBtn.addEventListener("click", restart);

    restart();
    loop();
  });
</script>