<section class="breathing-card">
    <h2>Respiration guidée</h2>
    <p id="instruction">Cliquez pour commencer</p>

    <button id="startBreathing" class="breathing-button">
        <span id="bubble"></span>
    </button>

    <p class="breathing-note">
        Inspirez lorsque la bulle grandit, expirez lorsqu'elle diminue...
    </p>
</section>

<style>
    .breathing-card {  /* Exercice complet */
        max-width: 500px;
        margin: 4rem auto;
        padding: 2rem;
        text-align: center;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.45);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }

    .breathing-card h2 {  /* Titre */
        color: #2f2f2f;
        font-size: 2rem;
    }

    #instruction {   /* Consignes */
        font-size: 1.2rem;
        color: #555;
        margin-bottom: 2rem;
    }

    .breathing-button {   /* Bouton circulaire */
        width: 220px;
        height: 220px;
        border: none;
        border-radius: 50%;
        background: transparent;
        cursor: pointer;
    }

    #bubble {   /* Bulle */
        display: block;
        width: 140px;
        height: 140px;
        margin: auto;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%,
            #b8d2bb 0%,
            #8FAF95 60%,
            #6c8b6f 100%);
        box-shadow: 0 0 35px rgba(108, 139, 111, 0.35);
        transform: scale(0.75);
    }

    #bubble.active {   /* Bulle animée */
        animation: breathing 10s infinite ease-in-out;
    }

    .breathing-note { /* Texte d'aide */
        margin-top: 2rem;
        font-size: 0.95rem;
        color: #777;
        font-style: italic;
    }

    @keyframes breathing { /* Animation */
        0% {
            transform: scale(0.75);
        }

        50% {
            transform: scale(1.25);
        }

        100% {
            transform: scale(0.75);
        }
    }

    @media (max-width: 768px) { /* Version mobile */
        .breathing-button {  /* Bouton circulaire */
            width: 180px;
            height: 180px;
        }

        #bubble { /* Bulle */
            width: 120px;
            height: 120px;
        }
    }
</style>

<script>
    const button = document.getElementById("startBreathing"); /* Recupère les différents éléments */
    const bubble = document.getElementById("bubble");
    const instruction = document.getElementById("instruction");

    let isActive = false;

    button.addEventListener("click", () => {  /* Détecte un clic sur la bulle */
        isActive = !isActive;

        if (isActive) {
            bubble.classList.add("active");  /* Lance l'animation */
            instruction.textContent = "Inspirez... puis expirez...";
        } else {
            bubble.classList.remove("active");   /* Arret animation */
            instruction.textContent = "Cliquez pour recommencer";
        }
    });
</script>
