<section class="breathing-card">
    <h2>Respiration guidée</h2>
    <p id="instruction">Cliquez pour commencer</p>

    <button id="startBreathing" class="breathing-button">
        <span id="bubble"></span>
    </button>

    <p class="breathing-note">
        Inspirez lorsque la bulle grandit, expirez lorsqu'elle diminue...
    </p>
    <p id="timer">05:00</p>
</section>

<style>
    .breathing-card {  /* Exercice complet */
        max-width: 500px;
        margin: 4rem auto;
        padding: 2rem;
        text-align: center;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.45);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }

    .breathing-card h2 {  /* Titre */
        color: #2f2f2f;
        font-size: 2rem;
    }

    #instruction {   /* Consignes */
        font-size: 1.2rem;
        color: #555;
        margin-bottom: 2rem;
    }

    .breathing-button {   /* Bouton circulaire */
        width: 220px;
        height: 220px;
        border: none;
        border-radius: 50%;
        background: transparent;
        cursor: pointer;
    }

    #bubble {   /* Bulle */
        display: block;
        width: 140px;
        height: 140px;
        margin: auto;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%,
            #b8d2bb 0%,
            #8FAF95 60%,
            #6c8b6f 100%);
        box-shadow: 0 0 35px rgba(108, 139, 111, 0.35);
        transform: scale(0.75);
    }

    #bubble.active {   /* Bulle animée */
        animation: breathing 10s infinite ease-in-out;
    }

    .breathing-note { /* Texte d'aide */
        margin-top: 2rem;
        font-size: 0.95rem;
        color: #777;
        font-style: italic;
    }

    #timer {    /* Chronometre */
        font-size: 1.5rem;
        font-weight: bold;
        color: #435c45;
        margin-bottom: 1.5rem;
    }

    @keyframes breathing { /* Animation */
        0% {
            transform: scale(0.75);
        }

        50% {
            transform: scale(1.25);
        }

        100% {
            transform: scale(0.75);
        }
    }

    @media (max-width: 768px) { /* Version mobile */
        .breathing-button {  /* Bouton circulaire */
            width: 180px;
            height: 180px;
        }

        #bubble { /* Bulle */
            width: 120px;
            height: 120px;
        }
    }
</style>

<script>
    const button = document.getElementById("startBreathing"); /* Récupération des données */
    const bubble = document.getElementById("bubble");
    const instruction = document.getElementById("instruction");
    const timerDisplay = document.getElementById("timer");

    let isActive = false;  /* Parametres */
    let timerInterval = null;
    let remainingTime = 300; // 5 minutes

    function updateTimer() {  /* Met a jour l'affichage du chronometre */
        const minutes = Math.floor(remainingTime / 60);
        const seconds = remainingTime % 60;

        timerDisplay.textContent =
            String(minutes).padStart(2, "0") +
            ":" +
            String(seconds).padStart(2, "0");
    }

    button.addEventListener("click", () => {  /* Détecte un clic sur la bulle */

        isActive = !isActive;

        if (isActive) {

            bubble.classList.add("active");  /* Lance l'animation de la bulle */
            instruction.textContent = "Inspirez... puis expirez...";  /* Modifie le texte des consignes affichées */

            remainingTime = 300;
            updateTimer();

            clearInterval(timerInterval);  /* Arrete le chronometre précedent s'il existe */

            timerInterval = setInterval(() => {

                remainingTime--;

                updateTimer();  /* Actualise l'affichage apres chaque seconde */

                if (remainingTime <= 0) {

                    clearInterval(timerInterval);

                    bubble.classList.remove("active");
                    instruction.textContent = "✔ Exercice terminé.";  /* Affiche le message de fin d'exercice */

                    isActive = false;
                }

            }, 1000);

        } else {

            bubble.classList.remove("active");
            instruction.textContent = "Cliquez pour recommencer"; /* Recommencer */

            clearInterval(timerInterval);

            remainingTime = 300;
            updateTimer(); /* Affiche immédiatement 5.00 a démarage de la page */
        }

    });

    updateTimer();
</script>