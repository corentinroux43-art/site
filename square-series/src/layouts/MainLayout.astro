---
import TopBar from "../components/TopBar.astro";
import NavigationButtons from "../components/NavigationButtons.astro";
import DidYouKnow from "../components/DidYouKnow.astro";
import FloatingButton from "../components/FloatingButton.astro";
import Signature from "../components/Signature.astro";
import Footnote from "../components/FootNote.astro";

const {
    title = "Corentin Roux - Ostéopathe D.O.",
    description = "Corentin Roux, ostéopathe à Saint-Just-Malmont. Consultations au cabinet et à domicile.",
    schema,
} = Astro.props;

const floatingLinks = [
    { href: "/prendre-rendez-vous", icon: "📅", label: "Prendre rendez-vous" },
    { href: "/jeux-salle-attente", icon: "🎮", label: "Jeux de salle d'attente" },
    { href: "/questions-frequentes", icon: "❓", label: "Questions fréquentes" },
];

const backToTopLink = {
    href: "#top",
    icon: "↑",
    label: "Retour en haut",
};
---

<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
</head>

<body id="top">
<TopBar />

<nav class="floating-buttons" aria-label="Accès rapides">
    {floatingLinks.map((link) => (
            <FloatingButton href={link.href} icon={link.icon} label={link.label} />
    ))}
</nav>

<nav class="back-to-top-button" aria-label="Retour en haut">
    <FloatingButton
            href={backToTopLink.href}
            icon={backToTopLink.icon}
            label={backToTopLink.label}
    />
</nav>

<DidYouKnow />

<NavigationButtons />

<main>
    <slot />

    <Signature />
    <Footnote />
</main>
</body>
</html>

<style is:global>
    :root {
        --green: #6c8b6f;
        --green-dark: #5f7252;
        --cream: rgba(248, 245, 240, 0.68);
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }

    * {
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        min-height: 100vh;
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif;

        background-image: url("/Background.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    @media (max-width: 768px) {

        body {

            background-image: url("/Backgroundphone.png");

            background-size: 100% auto;

            background-position: top center;

        }

    }
</style>

<style>
    main {
        width: min(1100px, calc(100% - 2rem));
        margin: 3rem auto;
    }

    .floating-buttons {
        position: fixed;
        top: 90px;
        right: 20px;
        z-index: 50;

        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .back-to-top-button {
        position: fixed;
        bottom: 30px;
        right: 20px;

        z-index: 999;
    }

    @media (max-width: 768px) {
        main {
            width: calc(100% - 1.25rem);
            margin: 2rem auto;
        }

        .floating-buttons {
            top: auto;
            right: 12px;
            bottom: 16px;
        }

        .back-to-top-button {
            right: 12px;
            bottom: 210px;
        }
    }
</style>
